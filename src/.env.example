#ai
# ============================================================
# AI CHAT CONFIGURATION (دکتر آنلاین)
# ============================================================
# تنظیمات عمومی چت
CHAT_SESSION_LIFETIME=1440              # ۱ روز (به دقیقه)
CHAT_AUTO_CLEANUP=true                  # پاکسازی خودکار
CHAT_CLEANUP_DAYS=1                     # چند روز نگهداری شود

# تنظیمات مدل هوش مصنوعی
CHAT_DEFAULT_MODEL=qwen3:14b
CHAT_FALLBACK_MODEL=llama3.1
CHAT_EMERGENCY_MODEL=qwen3:14b
CHAT_MODEL_TIMEOUT=120                  # زمان تایم‌اوت به ثانیه

# تنظیمات فیلتر پزشکی
CHAT_FILTER_ENABLED=true
CHAT_FILTER_STRICT=true                 # فقط سوالات پزشکی

# تنظیمات اورژانس
EMERGENCY_ENABLED=true
EMERGENCY_PHONE=115
EMERGENCY_AUTO_RESPOND=true

# تنظیمات فایل
CHAT_FILE_MAX_SIZE=5120                 # ۵ مگابایت
CHAT_ALLOWED_FILE_TYPES=jpg,jpeg,png,gif,pdf,doc,docx

# محدودیت نرخ درخواست
CHAT_RATE_LIMIT_PER_MINUTE=10
CHAT_RATE_LIMIT_PER_HOUR=100
CHAT_RATE_LIMIT_PER_DAY=500

# اتصال به Ollama
OLLAMA_URL=http://host.docker.internal:11434   # چون در Docker هستیم
OLLAMA_MODEL=qwen3:14b
OLLAMA_TIMEOUT=60
OLLAMA_MAX_RETRIES=3

OLLAMA_URL=http://medikall-ollama:11434
OLLAMA_MODEL=qwen3:14b
OLLAMA_CONNECTION_TIMEOUT=120
# تنظیمات پاکسازی
CHAT_CLEANUP_BATCH_SIZE=1000
CHAT_CLEANUP_SCHEDULE=0 0 * * *          # اجرا هر روز ساعت ۰۰:۰۰
CHAT_SESSION_LIFETIME=1440
CHAT_DEFAULT_MODEL=qwen3:14b
CHAT_FILTER_ENABLED=true
